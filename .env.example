# Copy to .env and fill in values.

# Optional: absolute path to this repo on Airflow workers (if imports fail without it)
# CTI_PROJECT_ROOT=/Users/you/final_project

SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_DATABASE=CTI_PLATFORM_DATABASE
SNOWFLAKE_SCHEMA=PUBLIC
SNOWFLAKE_WAREHOUSE=COMPUTE_WH

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
# Required for Airflow NVD DAGs (nvd_fetch_dag / nvd_transform_dag / nvd_load_dag) on S3.
S3_BUCKET=

# NVD CVE API 2.0 — optional; see https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=
# Optional: override seconds between NVD requests (default ~6s without key, ~0.65s with key)
# NVD_MIN_REQUEST_INTERVAL_SEC=

DEBUG=false

# Streamlit CTI console (streamlit_cti/Home.py) — FastAPI root URL
# CTI_API_BASE=http://127.0.0.1:8000

# Neo4j AuraDB — copy URI + username + password from ONE instance’s Connect modal (they must match).
NEO4J_URI=
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=
# Optional: graph database name. Leave empty to use the instance default / home database.
NEO4J_DATABASE=

# --- Docker Airflow (docker/docker-compose.airflow.yml) ---
# Pass --env-file .env from repo root for Snowflake/NVD and other app vars, e.g.:
#   docker compose --env-file .env -f docker/docker-compose.airflow.yml up --build -d
# AIRFLOW_FERNET_KEY is optional: compose embeds a dev-only default for local UI tests.
# Set your own for anything beyond solo local use: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# AIRFLOW_FERNET_KEY=
# Optional: match host uid on Linux so mounted repo files stay writable (default 50000)
# AIRFLOW_UID=50000
# Optional Flask session secret for the webserver (defaults in compose for local dev only)
# AIRFLOW_WEBSERVER_SECRET_KEY=
